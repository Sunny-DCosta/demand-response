        <mxCell id="e1" value="ingest" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2369D2;fontColor=#1A2233;endArrow=classic;fontSize=11;" edge="1" parent="1" source="ingest" target="lake">
          <mxGeometry relative="1" as="geometry" />
