        <mxCell id="e3" value="query tables / results" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2369D2;fontColor=#1A2233;startArrow=classic;endArrow=classic;fontSize=11;" edge="1" parent="1" source="lake" target="agent">
          <mxGeometry relative="1" as="geometry" />
